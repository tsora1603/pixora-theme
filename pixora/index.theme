[Icon Theme]
Name=Pixora
Comment=16 bit icon theme, pixelitos-icon-theme as fallback
Inherits=pixelitos-dark,breeze-dark,hicolor
Directories=scalable/apps,scalable/places

[scalable/apps]
Size=16
Context=Applications
Type=Scalable
MinSize=8
MaxSize=512

[scalable/places]
Size=16
Context=Places
Type=Scalable
MinSize=8
MaxSize=512
